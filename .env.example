APP_NAME="MAHHFAZ College of Health Sciences and Technology, Jalingo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# In production (Laravel Cloud) set: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-app.laravel.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Include the 'sentry' channel so Log::error()/critical()+ also become Sentry
# issues, which the self-healing pipeline then triages. Set the same value in
# Laravel Cloud env for production. Requires SENTRY_LARAVEL_DSN to be set.
LOG_STACK=single,sentry
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Error alerting (Sentry). Leave DSN blank to disable (app runs normally).
# Create a free project at sentry.io -> Laravel, copy the DSN here / into Cloud env.
SENTRY_LARAVEL_DSN=
# Performance tracing sample rate (0 = errors only, keeps you in the free tier).
SENTRY_TRACES_SAMPLE_RATE=0
# Keep PII OUT of Sentry: do not attach user emails/ids to events. Important for
# student/staff data. Leave false (also rely on Sentry's server-side scrubbing).
SENTRY_SEND_DEFAULT_PII=false

# Anthropic Claude — AI weekly-timetable generation. Leave blank to use the
# built-in deterministic generator (still guaranteed clash-free).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# If the primary model is overloaded/unreachable, generation retries on this
# faster, cheaper model before falling back to the deterministic generator.
# Leave blank to skip the step-down (deterministic stays the final floor).
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5

# Paystack online payments (application / acceptance / registration fees).
# Per-college keys on the College record take precedence over these platform
# defaults. With NO secret key set and APP_ENV != production, the app uses a
# sandbox auto-confirm so the payment flow can be tested before live keys.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
# Last-resort gateway email when an invoice's payer (and their college) has no
# deliverable address. Real students register with a valid email, so this is a
# safety net (and lets the seeded *.test accounts reach the gateway in testing).
PAYSTACK_FALLBACK_EMAIL=
# In the Paystack dashboard (Settings → API Keys & Webhooks) set:
#   Callback URL: https://<your-domain>/payments/callback
#   Webhook URL:  https://<your-domain>/paystack/webhook   (signature-verified)

# Local dev uses SQLite (zero-config). On Laravel Cloud, attach a managed
# MySQL/Postgres database and Cloud injects these vars automatically.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=school_portal
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# In production set SESSION_SECURE_COOKIE=true (cookies only sent over HTTPS).
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
# Local: "public" (run php artisan storage:link). Production: "s3" for persistent uploads.
FILESYSTEM_DISK=public
# Disk for uploaded admission/registration documents. Local: "public".
# Laravel Cloud: set "s3" (with AWS_* below) so documents survive redeploys.
DOCUMENTS_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email: "log" writes mails to storage/logs (dev). For real emails use SMTP.
# Example for Brevo/Mailtrap/Gmail/Resend-SMTP — fill from your provider:
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@yourschool.edu"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage (S3-compatible) for persistent uploads in production.
# On Laravel Cloud, attach object storage and it injects these automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_URL=            # public base URL of the bucket (set if not auto-derived)
# AWS_ENDPOINT=       # for non-AWS S3 (Cloudflare R2, MinIO, etc.)

VITE_APP_NAME="${APP_NAME}"

# Platform root domain for tenant subdomains: <acronym>.PLATFORM_DOMAIN (one wildcard DNS).
PLATFORM_DOMAIN=
